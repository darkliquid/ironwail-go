# Ignore everything by default
*

# Keep directory traversal so nested allow rules work
!*/

# Keep Go source files
!*.go

# Keep license/readme files
!/LICENSE.*
!/README.*

# Keep core module/task files at repo root
!/mise.toml
!/go.mod
!/go.sum

# Keep this file
!.gitignore
!/docs/*.md
!/docs/*.txt

# bv (beads viewer) local config and caches
.bv/

# Dolt database files (added by bd init)
.dolt/
*.db

.gemini/
gha-creds-*.json

# Beads / Dolt files (added by bd init)
.beads-credential-key
